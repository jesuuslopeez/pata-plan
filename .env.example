# ============================================
# PataPlan - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/pataplan

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Authentication (JWT) ----
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173

# ---- File Uploads ----
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=uploads

# ---- Docker (PostgreSQL) ----
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=pataplan
